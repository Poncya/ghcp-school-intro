---
const base = import.meta.env.BASE_URL;
const nav = [
  { href: '#about', jp: '特徴', en: 'About' },
  { href: '#learn', jp: '学び', en: 'Learning' },
  { href: '#access', jp: 'アクセス', en: 'Access' },
  { href: '#faq', jp: 'FAQ', en: 'FAQ' },
];
---
<header class="sticky top-0 z-40 bg-paper/80 backdrop-blur-md ring-1 ring-black/5">
  <div class="container-page flex h-16 items-center justify-between">
    <a href={base} class="no-underline">
      <span class="block text-base font-semibold tracking-tight">神山まるごと高専</span>
      <span class="block text-[11px] text-ink-muted tracking-[0.18em] uppercase">Kamiyama Marugoto College</span>
    </a>
    <nav aria-label="ページ内ナビゲーション">
      <ul class="hidden md:flex items-center gap-8 text-sm">
        {nav.map((n) => (
          <li>
            <a href={n.href} class="no-underline text-ink hover:text-accent transition">
              <span>{n.jp}</span>
              <span class="ml-2 text-ink-muted text-xs">{n.en}</span>
            </a>
          </li>
        ))}
      </ul>
      <a href="#contact" class="btn-primary md:hidden">お問い合わせ</a>
    </nav>
  </div>
</header>
