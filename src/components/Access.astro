---
const items = [
  { jp: '所在地', en: 'Location', value: '〒771-3310 徳島県名西郡神山町神領字中津132番地', valueEn: '132 Nakatsu, Jinryo, Kamiyama, Myozai-gun, Tokushima 771-3310, Japan' },
  { jp: '開校', en: 'Opened', value: '2023年4月', valueEn: 'April 2023' },
  { jp: '課程', en: 'Program', value: '5年一貫・全寮制', valueEn: '5-year integrated, fully residential' },
];
---
<section id="access" class="section">
  <div class="container-page grid lg:grid-cols-12 gap-10 lg:gap-14">
    <div class="lg:col-span-5 reveal">
      <span class="eyebrow">Access / アクセス</span>
      <h2 class="mt-4 text-display-lg font-semibold">徳島・神山の山あいで。</h2>
      <p class="en mt-3">In the mountains of Kamiyama, Tokushima.</p>
      <p class="mt-6 text-ink-soft leading-relaxed max-w-prose">
        自然と地域に囲まれた環境で、学びと暮らしが一体になったキャンパス生活を送ります。
      </p>
      <p class="en mt-2 max-w-prose">
        A campus where learning and daily life merge — surrounded by forests and community.
      </p>
    </div>

    <dl class="lg:col-span-7 grid gap-5 sm:grid-cols-2 reveal">
      {items.map((i) => (
        <div class="card p-6 md:p-7">
          <dt class="flex items-baseline justify-between gap-3">
            <span class="text-sm font-semibold text-ink">{i.jp}</span>
            <span class="text-xs text-ink-muted tracking-[0.14em] uppercase">{i.en}</span>
          </dt>
          <dd class="mt-3 text-ink-soft leading-relaxed">{i.value}</dd>
          <dd class="en mt-1">{i.valueEn}</dd>
        </div>
      ))}
      <div class="card p-6 md:p-7 sm:col-span-2">
        <dt class="flex items-baseline justify-between gap-3">
          <span class="text-sm font-semibold">公式サイト</span>
          <span class="text-xs text-ink-muted tracking-[0.14em] uppercase">Official</span>
        </dt>
        <dd class="mt-3">
          <a class="text-accent hover:underline" href="https://kamiyama.ac.jp/" rel="noopener noreferrer" target="_blank">
            kamiyama.ac.jp
          </a>
        </dd>
      </div>
    </dl>
  </div>
</section>
