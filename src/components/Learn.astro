---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const learnImg = `${base}images/learn.svg`;

const pillars = [
  {
    no: '01',
    jp: 'テクノロジー',
    en: 'Technology',
    body: 'プログラミング、AI、電子工作まで。手を動かしながら原理を学ぶ。',
    bodyEn: 'From programming and AI to electronics — learn by building.',
  },
  {
    no: '02',
    jp: 'デザイン',
    en: 'Design',
    body: '課題を捉え直し、体験を形にするデザイン思考を鍛える。',
    bodyEn: 'Reframe problems and shape experiences through design thinking.',
  },
  {
    no: '03',
    jp: '起業家精神',
    en: 'Entrepreneurship',
    body: 'アイデアを事業に育てるプロセスを、実践と伴走で学ぶ。',
    bodyEn: 'Grow ideas into ventures through practice and mentorship.',
  },
];
---
<section id="learn" class="section bg-paper-warm/60">
  <div class="container-page grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">
    <div class="lg:col-span-5 reveal">
      <figure class="overflow-hidden rounded-3xl ring-1 ring-black/5 shadow-soft aspect-[4/5] bg-paper">
        <img src={learnImg} alt="学びの様子のイメージ（プレースホルダ）" class="h-full w-full object-cover" loading="lazy" decoding="async" />
      </figure>
    </div>

    <div class="lg:col-span-7">
      <div class="reveal">
        <span class="eyebrow">Learning / 学び</span>
        <h2 class="mt-4 text-display-lg font-semibold">
          3つの柱で、未来をつくる人を育てる。
        </h2>
        <p class="en mt-3">Three pillars that shape creators of the future.</p>
      </div>

      <ol class="mt-10 space-y-8">
        {pillars.map((p) => (
          <li class="reveal">
            <div class="flex items-baseline gap-5">
              <span class="text-accent font-display text-lg tracking-widest">{p.no}</span>
              <div>
                <h3 class="text-xl md:text-2xl font-semibold">
                  {p.jp}
                  <span class="ml-3 text-ink-muted text-sm tracking-[0.14em] uppercase font-normal">{p.en}</span>
                </h3>
                <p class="mt-3 text-ink-soft leading-relaxed max-w-prose">{p.body}</p>
                <p class="en mt-1 max-w-prose">{p.bodyEn}</p>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
